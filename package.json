{
  "name": "projeto-portaliptv",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "build": "vite build",
    "dist": "vite build && node --experimental-require-module ./node_modules/electron-builder/cli.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "mobile:sync": "vite build && cap sync"
  },
  "build": {
    "appId": "com.portaliptv.app",
    "productName": "Portal IPTV",
    "win": {
      "target": "nsis",
      "publish": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "differentialPackage": false
    },
    "directories": {
      "output": "C:/PortalIPTV_Build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "hls.js": "^1.6.16",
    "localforage": "^1.10.0",
    "lucide-react": "^1.18.0",
    "mpegts.js": "^1.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
  }
}
